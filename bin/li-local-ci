#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=../lib/runner.sh
source "$ROOT/lib/runner.sh"

main() {
  case "${1:-}" in
    run)
      shift
      cmd_run "$@"
      ;;
    run-pr)
      shift
      # shellcheck source=../lib/run-pr.sh
      source "$ROOT/lib/run-pr.sh"
      cmd_run_pr "$@"
      ;;
    workflows)
      shift
      # shellcheck source=../lib/workflow-run.sh
      source "$ROOT/lib/workflow-run.sh"
      cmd_run_workflows "$@"
      ;;
    list)
      cmd_list
      ;;
    doctor)
      cmd_doctor
      ;;
    build-images)
      shift
      exec "$ROOT/scripts/build-images.sh" "$@"
      ;;
    prune)
      shift
      exec "$ROOT/scripts/prune.sh" "$@"
      ;;
    -h | --help | help | "")
      sed -n '1,80p' "$ROOT/README.md"
      echo ""
      echo "Usage:"
      echo "  li-local-ci run <profile> [--repo PATH] [--no-prune] [--dry-run]"
      echo "  li-local-ci run-pr --repo NAME --pr N [--workflow FILE --event EVENT] [--profile workflows|legacy]"
      echo "  li-local-ci workflows --repo PATH [--workflow FILE --event EVENT] [--all-pr-workflows]"
      echo "  li-local-ci list | doctor | build-images | prune"
      echo ""
      echo "Default run-pr mode: execute .github/workflows/*.yml via act (brew install act)."
      echo "Legacy shell profiles: --profile li-cursor-agents-host (etc.)"
      ;;
    *)
      echo "Unknown command: $1 (try --help)" >&2
      exit 1
      ;;
  esac
}

main "$@"
